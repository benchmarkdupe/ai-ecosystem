# AI Gateway -> OpenRouter
# OPENROUTER_API_KEY still needs a real key from openrouter.ai (free to create,
# no payment required) - the :free models below just don't cost credits to call.
OPENROUTER_API_KEY=
# Fallback model for any AI Gateway call that doesn't specify one. Free tier:
# no credits required, 50 req/day / 20 req/min per account. If this ID stops
# resolving, check https://openrouter.ai/models?max_price=0 for the current list.
OPENROUTER_DEFAULT_MODEL=openai/gpt-oss-20b:free

# Opportunity Engine's research/script generation each run as a 2-agent chain
# (draft, then a review/critic pass by a second, more reasoning-heavy model).
# Both draw from the same free-tier daily budget above.
AI_MODEL_DRAFT=openai/gpt-oss-20b:free
AI_MODEL_CRITIC=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# Shared-secret auth for external callers (e.g. an Opportunity OS frontend)
# hitting these services directly. Leave blank to disable (local/dev use).
API_KEY=

# YouTube Worker -> YouTube Data API v3 (publish + analytics)
# See services/youtube-worker/scripts/get-refresh-token.js to obtain a refresh token.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_DEFAULT_PRIVACY=private
